<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_auto_start"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/margin_small"
    android:paddingBottom="@dimen/padding_small"
    app:cardBackgroundColor="@color/primary_blue_10"
    app:cardCornerRadius="@dimen/radius_large"
    app:cardElevation="0dp"
    app:strokeColor="@color/primary_blue"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_medium">

        <ImageView
            android:id="@+id/iv_autostart_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_48dp_primary"
            android:padding="12dp"
            android:src="@android:drawable/stat_sys_data_bluetooth"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_autostart_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_medium"
            android:text="@string/autostart_banner_title"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_autostart_icon"
            app:layout_constraintTop_toTopOf="@id/iv_autostart_icon" />

        <TextView
            android:id="@+id/tv_autostart_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_medium"
            android:text="@string/autostart_banner_desc"
            android:textColor="@color/text_secondary_on_dark"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_autostart_icon"
            app:layout_constraintTop_toBottomOf="@id/tv_autostart_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
