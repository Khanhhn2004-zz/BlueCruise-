<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutFloatingBubbleRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/bg_floating_bubble_container">

    <ImageButton
        android:id="@+id/btnFloatingSong1"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_floating_bubble_button"
        android:contentDescription="@string/song_1_label"
        android:padding="12dp"
        android:src="@drawable/ic_greeting_round" />

    <ImageButton
        android:id="@+id/btnFloatingSong2"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_floating_bubble_button"
        android:contentDescription="@string/song_2_label"
        android:padding="12dp"
        android:src="@drawable/ic_goodbye_round" />

</LinearLayout>
