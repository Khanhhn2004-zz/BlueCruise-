<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cvTargetCar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/margin_small"
    android:padding="@dimen/padding_small"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvTargetDeviceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Vinfast VF8" />

            <TextView
                android:id="@+id/tv_target_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/target_bluetooth_device"
                android:textColor="@color/primary_blue"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/clAudioPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_audio_picker"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/cvMusicIconContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_48dp_primary_10">

                <ImageView
                    android:id="@+id/ivMusicIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_greeting_round"
                    app:tint="@color/primary_blue" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/song_1_label"
                    android:textColor="@color/text_secondary_on_dark"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvAudioFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/select_audio_file"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivSettingsIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/clAudioPicker2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_audio_picker"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/cvMusicIconContainer2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_48dp_primary_10">

                <ImageView
                    android:id="@+id/ivMusicIcon2"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_goodbye_round"
                    app:tint="@color/primary_blue" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/song_2_label"
                    android:textColor="@color/text_secondary_on_dark"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvAudioFile2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/select_audio_file"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivSettingsIcon2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_gray" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManualPlayStop"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/play_now"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/black"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_play_round"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="22dp"
            app:iconTint="@color/white"
            app:rippleColor="#30FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSyncServer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/sync_server"
            android:textAllCaps="false"
            android:textColor="@color/primary_blue"
            app:cornerRadius="18dp"
            app:iconPadding="8dp"
            app:iconTint="@color/primary_blue"
            app:strokeColor="@color/primary_blue" />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:alpha="0.3"
            android:background="@color/card_stroke" />

        <LinearLayout
            android:id="@+id/layoutAutoPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAutoPlayTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_play"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAutoPlayDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_play_desc"
                    android:textColor="@color/text_muted_on_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoPlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                app:rippleColor="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAutoPlayOnAndroidAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAutoPlayOnAndroidAutoTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_play_on_android_auto"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAutoPlayOnAndroidAutoDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_play_on_android_auto_desc"
                    android:textColor="@color/text_muted_on_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoPlayOnAndroidAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                app:rippleColor="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAftermarketAndroidAutoTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAftermarketAndroidAutoTargetTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aftermarket_android_auto_target"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAftermarketAndroidAutoTargetDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aftermarket_android_auto_target_desc"
                    android:textColor="@color/text_muted_on_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAftermarketAndroidAutoTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                app:rippleColor="@android:color/transparent" />
        </LinearLayout>



        <LinearLayout
            android:id="@+id/layoutKeepAlive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvKeepAliveTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/keep_alive"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvKeepAliveDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/keep_alive_desc"
                    android:textColor="@color/text_muted_on_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchKeepAlive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                app:rippleColor="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutFloatingBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFloatingBubbleTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/floating_bubble"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFloatingBubbleDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/floating_bubble_desc"
                    android:textColor="@color/text_muted_on_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchFloatingBubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                app:rippleColor="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutConnectionStartDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_rounded_16dp_ripple"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvConnectionStartDelayTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_start_delay"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvConnectionStartDelayDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_start_delay_desc"
                        android:textColor="@color/text_muted_on_dark"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvConnectionStartDelayValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="3 giay" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderConnectionStartDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:valueFrom="0"
                android:valueTo="10"
                android:stepSize="1"
                app:haloColor="@color/primary_blue"
                app:labelBehavior="gone"
                app:thumbColor="@color/primary_blue"
                app:trackColorActive="@color/primary_blue"
                app:trackColorInactive="@color/card_stroke"
                tools:value="3" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:alpha="0.2"
            android:background="@color/card_stroke" />

        <TextView
            android:id="@+id/tv_tier_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/routing_tier"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroupTier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:checkedButton="@id/btnTier1"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTier1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tier_1"
                android:textSize="12sp"
                app:strokeColor="@color/primary_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTier2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tier_2"
                android:textSize="12sp"
                app:strokeColor="@color/primary_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTier3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tier_3"
                android:textSize="12sp"
                app:strokeColor="@color/primary_blue" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/tvTierDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tier_1_desc"
            android:textColor="@color/text_muted_on_dark"
            android:textSize="11sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
